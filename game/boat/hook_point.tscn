[sub_resource type="GDScript" id="GDScript_sff1j"]
resource_name = "Hook"
script/source = "@tool
extends Node2D

@export var length := 0.0
@export var angle := 0.0 : # rad
	get:
		return angle
	set(v):
		angle = v
		root.rotation = angle

@export var hook_turn_speed := 1.0 # rad per second

@export var hook_shoot_acc := 2.0
@export var hook_shoot_max_speed := 2.0
@export var hook_shoot_max_range := 100.0
var velocity :float

var activating := false
var _shooted := false

@onready var root := %root
@onready var hook := %hook
@onready var chain := %chain

func _process(delta):
	hook.position.y = length
	chain.set_point_position(0, root.position)
	chain.set_point_position(1, root.transform * hook.position)
	if !Engine.is_editor_hint():
		_runtime_process(delta)
	else:
		queue_redraw()

func _draw():
	draw_circle(%root.position, hook_shoot_max_range, Color(0,0.2,0.8, 0.3))

func _runtime_process(delta: float):
	if !_shooted && activating:
		if Input.is_action_pressed(\"hook_left\"):
			angle += hook_turn_speed * delta
		elif Input.is_action_pressed(\"hook_right\"):
			angle -= hook_turn_speed * delta
		if Input.is_action_just_pressed(\"hook_shoot\"):
			shoot()

func shoot():
	_shooted = true
	while length < hook_shoot_max_range:
		var acc = 1.0 if hook_shoot_acc <= 0.0 else hook_shoot_acc
		velocity += acc
		length += velocity
		await get_tree().process_frame
	velocity = 0.0
	await get_tree().create_timer(0.5).timeout
	while length >= 0:
		var acc = 1.0 if hook_shoot_acc <= 0.0 else hook_shoot_acc
		velocity -= acc
		length += velocity
		await get_tree().process_frame
	velocity = 0.0
	_shooted = false
	toggle_activate(activating)

func toggle_activate(on: bool):
	activating = on
	toggle_hook(on)
	if !_shooted:
		toggle_hook(on)
		length = 10 if on else 0
		angle = 0 if not on else angle

func toggle_hook(on: bool):
	hook.frame = 0 if on else 1
"

